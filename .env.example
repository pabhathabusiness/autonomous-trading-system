# Copy this file to .env and fill in real values. Never commit .env.
# Robinhood login is via the unofficial robin_stocks library (no official
# public trading API exists). Leave these blank to run the system in
# read-only/offline mode (yfinance-only quotes, no live account data).
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
# TOTP secret if you have 2FA app-based auth configured on Robinhood
# (Settings > Security > Authenticator App), used to auto-generate MFA codes.
ROBINHOOD_TOTP_SECRET=
