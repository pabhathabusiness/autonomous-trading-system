  "autonomous": {
    "auto_execute": false,
    "auto_execute_accounts": ["algo"],
    "scan_interval_min": 15,
    "monitor_interval_sec": 60,
    "market_hours_only": true,
    "bands": {"day_trade": true, "short_term": true, "swing": true},
    "note": "auto_execute stays FALSE until you deliberately enable it on the server. Only 'algo' (paper) may ever be listed here; real-money accounts are hard-blocked by execution_guard."
  },
  "risk": {
    "max_open_risk_pct": 5.0,
    "daily_loss_limit_pct": -2.0,
    "drawdown_kill_pct": -10.0,
    "per_lane_cap_pct": 30.0,
    "max_positions_per_sector": 3,
    "liquidity_max_adv_participation_pct": 1.0,
    "liquidity_min_price": 0.20,
    "liquidity_min_dollar_vol": 300000,
    "earnings_blackout_days": 2,
    "note": "Portfolio-level risk gate for Alpaca PAPER order placement (B3). Every control fails CLOSED: a missing input REFUSES the trade. max_open_risk = sum of open+pending position risk as pct of equity; daily_loss halts new opens at -2% of day-start equity; drawdown_kill halts ALL opens at -10% below the equity high-water mark (persists across restart); per_lane_cap = max open notional per lane as pct of equity; max_positions_per_sector is the correlation cap; liquidity guard bounds order size vs ADV and floors price/dollar-volume."
  },
  "smallcap": {
    "enabled": false,
    "notional": {"runner": 2500, "bounce": 3000, "value": 4000, "hailmary": 1500},
    "note": "Addendum 2 quarantined sub-$5 lane. OFF by default. When true, the scheduler runs a daily premarket universe build (~5000 names, needs FINNHUB_KEY) + fast lane scans that auto-open book='smallcap' PAPER trades. Never real, never Alpaca; Hail-Mary is permanently paper + caged (max 2 open). Fully separate from the main book's stats."
  },
